<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="container">
        <div class="header">
            <h1><%= title %></h1>
            <a href="/logout" class="logout-btn">Logout</a>
        </div>
        <div style="clear: both;">
            <a href="/food/new_category">+ Add New Category</a>
            <ul style="margin-top: 20px;">
                <% categories.forEach(category => { %>
                    <li><a href="/food/<%= category %>"><%= category %></a></li>
                <% }); %>
            </ul>
        </div>
    </div>
</body>
</html>