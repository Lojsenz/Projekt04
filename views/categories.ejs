<%- include("header.ejs") %>
<main>
  <h1><%= title %></h1>
  <ul id="categories">
    <% categories.forEach(function(category){ %>
    <li>
      <a href="/food/<%= category %>"><%= category %></a>
      <form method="POST" action="/food/<%= category %>/delete" style="display:inline;">
        <button type="submit" onclick="return confirm('Are you sure you want to delete this category and all its recipes?')">Delete</button>
      </form>
    </li>
    <% }) %>
  </ul>
  <a href="/food/new_category">Dodaj nową kategorię</a>
</main>
<%- include("footer.ejs") %>