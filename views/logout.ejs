<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logout</title>
    <style>
        body {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            font-family: Arial, sans-serif;
        }
        .logout-container {
            background: white;
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            text-align: center;
            max-width: 400px;
        }
        h1 {
            color: #333;
            margin-top: 0;
        }
        p {
            color: #666;
            font-size: 16px;
            margin-bottom: 30px;
        }
        .logout-icon {
            font-size: 60px;
            margin-bottom: 20px;
        }
        .button-group {
            display: flex;
            gap: 10px;
        }
        a, button {
            flex: 1;
            padding: 12px;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
            transition: all 0.3s;
        }
        .btn-login {
            background: #667eea;
            color: white;
        }
        .btn-login:hover {
            background: #5568d3;
        }
        .btn-home {
            background: #f0f0f0;
            color: #333;
            border: 1px solid #ddd;
        }
        .btn-home:hover {
            background: #e0e0e0;
        }
    </style>
</head>
<body>
    <div class="logout-container">
        <div class="logout-icon">👋</div>
        <h1>You have been logged out</h1>
        <p>Your session has been safely ended. You are now logged out of your account.</p>
        <div class="button-group">
            <a href="/login" class="btn-login">Login Again</a>
            <a href="/register" class="btn-home">Register</a>
        </div>
    </div>
</body>
</html>